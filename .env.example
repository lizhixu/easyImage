NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# SQLite local: file:./data/easyimage.db
# Turso: libsql://your-db.turso.io
DATABASE_URL=file:./data/easyimage.db
DATABASE_AUTH_TOKEN=

JWT_SECRET=change-this-long-random-secret
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=30
ALLOW_ANONYMOUS_UPLOAD=true
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp,ico,jfif,tif,tiff,svg
NSFWJS_URL=http://127.0.0.1:3307/api/nsfw/classify
NSFWJS_THRESHOLD=0.6

# S3 也可以在后台管理页修改。这里的值只作为首次初始化默认值。
# 如果两个存储桶在同一服务商下，可以继续使用这组公共默认值。
S3_REGION=auto
S3_ENDPOINT=https://example.r2.cloudflarestorage.com
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

S3_BUCKET_NORMAL=easyimage
S3_BUCKET_SUSPICIOUS=easyimage-suspicious
S3_PUBLIC_BASE_URL=https://img.example.com
S3_SUSPICIOUS_PUBLIC_BASE_URL=

# 如果正常文件和可疑文件要完全分离，优先使用下面两组独立默认值。
S3_NORMAL_REGION=
S3_NORMAL_ENDPOINT=
S3_NORMAL_FORCE_PATH_STYLE=
S3_NORMAL_ACCESS_KEY_ID=
S3_NORMAL_SECRET_ACCESS_KEY=
S3_NORMAL_BUCKET=
S3_NORMAL_PUBLIC_BASE_URL=

S3_SUSPICIOUS_REGION=
S3_SUSPICIOUS_ENDPOINT=
S3_SUSPICIOUS_FORCE_PATH_STYLE=
S3_SUSPICIOUS_ACCESS_KEY_ID=
S3_SUSPICIOUS_SECRET_ACCESS_KEY=
S3_SUSPICIOUS_BUCKET=
S3_SUSPICIOUS_PUBLIC_BASE_URL=
